[Script]
DualSubs.Spotify.Lyrics.Translate.response = type=http-response, pattern=^https?:\/\/spclient\.wg\.spotify\.com\/color-lyrics\/v2\/track, requires-body=1, debug=1, script-path=https://raw.githubusercontent.com/DualSubs/Universal/beta/js/DualSubs.Subtitles.Translate.response.beta.js

[MITM]
hostname = %APPEND% spclient.wg.spotify.com
